{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "jupyter.jupyterCommandLineArguments": [
    "--IPKernelApp.connection_dir=${workspaceFolder}/.cursor-state/jupyter/runtime"
  ],
  "terminal.integrated.env.linux": {
    "JUPYTER_DATA_DIR": "${workspaceFolder}/.cursor-state/jupyter",
    "JUPYTER_CONFIG_DIR": "${workspaceFolder}/.cursor-state/jupyter/config",
    "IPYTHONDIR": "${workspaceFolder}/.cursor-state/ipython"
  },
  "workbench.editorAssociations": {
    "*.parquet": "duckdb.dataFileViewer",
    "*.csv": "duckdb.dataFileViewer",
    "*.tsv": "duckdb.dataFileViewer",
    "*.xlsx": "duckdb.dataFileViewer"
  }
}
